# PACTA Environment Configuration

# Required: Generate with openssl rand -base64 32
JWT_SECRET=change-me-later-generate-with-openssl-rand-base64-32

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# Node environment
NODE_ENV=production

# Server port (default)
PORT=3000
